{
  "name": "@prodmind/parser",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:stress": "vitest run --include='**/*.stress.test.ts'",
    "test:watch": "vitest",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@prodmind/contracts": "workspace:*",
    "@prodmind/shared": "workspace:*",
    "@prodmind/core": "workspace:*",
    "@prodmind/db": "workspace:*",
    "@zip.js/zip.js": "^2.7.0",
    "typescript": "^5.7.3"
  },
  "devDependencies": {
    "@types/node": "^22.12.0",
    "tsup": "^8.3.5",
    "vitest": "^3.0.4",
    "eslint": "^9.18.0"
  }
}
